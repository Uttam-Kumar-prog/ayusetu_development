PORT=5000
NODE_ENV=development
MONGO_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/<dbname>
JWT_SECRET=change-me-to-a-strong-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
WEB_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173
# Optional: regex for preview URLs, e.g. ^https://ayusetu(-[a-z0-9-]+)?\\.vercel\\.app$
CORS_ORIGIN_REGEX=
CORS_ALLOW_ALL=false
OTP_EXPIRY_MINUTES=5
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS=5
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_MINUTES=15
RESET_TOKEN_EXPIRES_MINUTES=10
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=25
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
PAYMENT_ORDER_EXPIRY_MINUTES=15

# OpenAI — optional, used for AI symptom structuring
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Email — optional, logs to console if not set
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password

# Reminder timing
REMINDER_MINUTES_BEFORE=15
